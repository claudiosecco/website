Sub add_query()

    Dim sCurrentMonthServicesTablePath As String
    Dim sServicesInMonthQuery As String

    sCurrentMonthServicesTablePath = Range("cellCurrentMonthServicesTablePath").Value

    sServicesInMonthQuery = "let" & Chr(13) & "" & Chr(10) & _
      "    Source = Csv.Document(File.Contents(" & Chr(34) & sCurrentMonthServicesTablePath & Chr(34) & "),[Delimiter="","", Columns=6, Encoding=1252, QuoteStyle=QuoteStyle.None])," & Chr(13) & "" & Chr(10) & _
      "    Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true])," & Chr(13) & "" & Chr(10) & _
      "    ColumnTypes = Table.TransformColumnTypes(Headers,{{""id_conta_mestre"", type text}, {""id_conta"", type text}, {""tipo"", type text}, {""categoria"", type text}, {""montante"", Currency.Type}, {""quantidade"", Int64.Type}})" & Chr(13) & "" & Chr(10) & _
      "in" & Chr(13) & "" & Chr(10) & _
      "    ColumnTypes"

    ' if query already exists, delete it first
    ActiveWorkbook.Queries.Item("advancements").Delete

    ' if table already populated in worksheet, ClearContents first
    Worksheets("advancements").Select
    Cells(1, 1).Select
    Range(Selection, Selection.End(xlDown)).Select
    Range(Selection, Selection.End(xlToRight)).Select
    Selection.ClearContents
    Cells(1, 1).Select

    ActiveWorkbook.Queries.Add Name:="advancements", Formula:=sServicesInMonthQuery

    With ActiveSheet.ListObjects.Add(SourceType:=0, Source:= _
      ' line bellow may need some adjustments to specific case
      "OLEDB;Provider=Microsoft.Mashup.OleDb.1;Data Source=$Workbook$;Location=advancements;Extended Properties=""""" _
      , Destination:=Range("$A$1")).QueryTable
      .CommandType = xlCmdSql
      .CommandText = Array("SELECT * FROM [advancements]")
      .RowNumbers = False
      .FillAdjacentFormulas = False
      .PreserveFormatting = True
      .RefreshOnFileOpen = False
      .BackgroundQuery = True
      .RefreshStyle = xlInsertDeleteCells
      .SavePassword = False
      .SaveData = True
      .AdjustColumnWidth = True
      .RefreshPeriod = 0
      .PreserveColumnInfo = True
      .ListObject.DisplayName = "advancements"
      .Refresh BackgroundQuery:=False
    End With

End Sub
